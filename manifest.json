{
  "manifest_version": 2,
  "name": "DomainGuard",
  "version": "1.0.0",
  "description": "Visibility and control over data stored by websites you visit.",

  "browser_specific_settings": {
    "gecko": {
      "id": "domain.guard@lamargreene.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "permissions": [
    "cookies",
    "tabs",
    "storage",
    "webRequest",
    "browsingData",
    "<all_urls>"
  ],

  "background": {
    "scripts": [
      "utils/domain.js",
      "background/tab-tracker.js",
      "background/request-logger.js",
      "background/deletion.js",
      "background/main.js"
    ]
  },

  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content/storage-reader.js"],
    "run_at": "document_idle"
  }],

  "sidebar_action": {
    "default_title": "DomainGuard",
    "default_panel": "sidebar/sidebar.html",
    "default_icon": "icons/icon-48.png"
  },

  "browser_action": {
    "default_title": "DomainGuard",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
